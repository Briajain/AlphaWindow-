{
  "manifest_version": 3,
  "name": "AlphaWindow | Research Scraper",
  "version": "1.0.1",
  "description": "Capture and analyze research fragments from X directly into your AlphaWindow dashboard.",
  "icons": {
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}